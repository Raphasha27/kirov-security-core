# Kirov Security Core — env prefix KC_
KC_APP_NAME=Kirov Security Core
KC_APP_VERSION=1.0.0
KC_DEBUG=false
KC_DATABASE_URL=sqlite+aiosqlite:///./kirov_core.db
KC_JWT_SECRET=change-me-in-production
KC_JWT_ALGORITHM=HS256
KC_ACCESS_TOKEN_EXPIRE_MINUTES=60
KC_CORS_ORIGINS=["http://localhost:3000"]
KC_OPENAI_API_KEY=
KC_OLLAMA_BASE_URL=http://localhost:11434
KC_OLLAMA_MODEL=llama3.2
KC_RATE_LIMIT_PER_MINUTE=60
KC_LOG_LEVEL=INFO

# Frontend (Next.js — no prefix)
NEXT_PUBLIC_API_URL=http://localhost:8000
